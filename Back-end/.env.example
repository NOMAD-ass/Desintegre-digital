# Copie este arquivo para ".env" (mesma pasta) e preencha com os dados reais.
# O arquivo .env nunca deve ser enviado pro GitHub (já está no .gitignore).

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=desintegre_digital

# Qualquer texto longo e aleatório serve. É usado para "assinar" o token
# de login (JWT) - se alguém souber essa chave, consegue forjar logins.
JWT_SECRET=troque-por-uma-chave-longa-e-aleatoria

PORT=3000
